# Example secrets file for Streamlit Community Cloud
# DO NOT commit the real secrets.toml — it is gitignored.
#
# When deploying on Streamlit Community Cloud:
#   App settings → Secrets → paste the contents below with REAL keys.
#
# Get free API keys here:
#   NREL_API_KEY     → https://developer.nrel.gov/signup/
#   GEMINI_API_KEY   → https://aistudio.google.com/app/apikey

NREL_API_KEY = "your_nrel_api_key_here"
GEMINI_API_KEY = "your_gemini_api_key_here"
